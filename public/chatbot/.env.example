OPENROUTER_API_KEY=your_openrouter_api_key_here
# Optional (OpenRouter recommends HTTP-Referer for rankings):
# OPENROUTER_HTTP_REFERER=http://localhost/
# OPENROUTER_APP_TITLE=Medical Chat Widget
# OPENROUTER_ENDPOINT=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_MODEL=deepseek/deepseek-chat-v3.1

RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX=12

CACHE_ENABLED=1
CACHE_TTL=120

MAX_REPLY_CHARS=900

# Comma-separated origins (optional). Keep empty for same-origin only.
# ALLOWED_ORIGINS=https://your-angular-site.com
